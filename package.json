{
  "name": "flywing-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "app.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx dev.ts",
    "build:client": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/server-core.js",
    "build": "npm run clean && npm run build:client && npm run build:server",
    "start": "node app.js",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "postinstall": "npm run build"
  },
  "dependencies": {
    "express": "^4.21.2",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "@supabase/supabase-js": "^2.104.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.0",
    "react-hook-form": "^7.72.1",
    "@hookform/resolvers": "^5.2.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0",
    "class-variance-authority": "^0.7.1",
    "tw-animate-css": "^1.4.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@google/genai": "^1.29.0",
    "shadcn": "^4.2.0",
    "vite": "^6.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@tailwindcss/vite": "^4.1.14",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "tailwindcss": "^4.1.14"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0"
  }
}
